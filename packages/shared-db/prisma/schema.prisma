generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users & Auth ──────────────────────────────────────────────

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  username           String    @unique @db.VarChar(50)
  email              String    @unique @db.VarChar(255)
  passwordHash       String    @map("password_hash") @db.VarChar(255)
  role               String    @db.VarChar(50) // co_owner, band_admin, band_member, promoter, label, fan
  githubId           String?   @map("github_id") @db.VarChar(100)
  githubUsername     String?   @map("github_username") @db.VarChar(100)
  githubAccessToken  String?   @map("github_access_token")
  firstLoginComplete Boolean   @default(false) @map("first_login_complete")
  coOwnerSignedAt    DateTime? @map("co_owner_signed_at")
  coOwnerSignedIp    String?   @map("co_owner_signed_ip") @db.VarChar(50)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  sessions          Session[]
  oneTimeTokens     OneTimeToken[]
  coOwnerSignatures CoOwnerSignature[]
  auditLogs         AuditLog[]
  bandMemberships   BandMember[]

  @@map("users")
}

model OneTimeToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  purpose   String    @db.VarChar(50) // first_login, password_reset, invite
  usedAt    DateTime? @map("used_at")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("one_time_tokens")
}

model Session {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  refreshTokenHash String   @map("refresh_token_hash") @db.VarChar(255)
  deviceInfo       Json?    @map("device_info")
  ipAddress        String?  @map("ip_address") @db.VarChar(50)
  expiresAt        DateTime @map("expires_at")
  createdAt        DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("sessions")
}

model CoOwnerSignature {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  agreementVersion String   @map("agreement_version") @db.VarChar(20)
  signedAt         DateTime @map("signed_at")
  ipAddress        String   @map("ip_address") @db.VarChar(50)
  userAgent        String?  @map("user_agent")
  agreementHash    String   @map("agreement_hash") @db.VarChar(255)

  user User @relation(fields: [userId], references: [id])

  @@map("co_owner_signatures")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar(100)
  resource  String?  @db.VarChar(100)
  metadata  Json?
  ipAddress String?  @map("ip_address") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_log")
}

// ── Bands & Content ───────────────────────────────────────────

model Band {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @db.VarChar(255)
  slug           String   @unique @db.VarChar(100)
  tier           String   @db.VarChar(50) // emerging, touring, arena, stadium
  storageQuotaGb Int      @default(500) @map("storage_quota_gb")
  storageUsedGb  Decimal  @default(0) @map("storage_used_gb")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  members BandMember[]
  tours   Tour[]
  shows   Show[]

  @@map("bands")
}

model BandMember {
  id          String   @id @default(uuid()) @db.Uuid
  bandId      String   @map("band_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  role        String   @db.VarChar(50) // owner, manager, artist, crew, viewer
  permissions Json?
  joinedAt    DateTime @default(now()) @map("joined_at")

  band Band @relation(fields: [bandId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@map("band_members")
}

model Tour {
  id               String   @id @default(uuid()) @db.Uuid
  bandId           String   @map("band_id") @db.Uuid
  name             String   @db.VarChar(255)
  startDate        DateTime? @map("start_date") @db.Date
  endDate          DateTime? @map("end_date") @db.Date
  status           String   @default("planning") @db.VarChar(50)
  productionConfig Json?    @map("production_config")
  createdAt        DateTime @default(now()) @map("created_at")

  band  Band   @relation(fields: [bandId], references: [id])
  shows Show[]

  @@map("tours")
}

model Show {
  id             String   @id @default(uuid()) @db.Uuid
  tourId         String   @map("tour_id") @db.Uuid
  bandId         String   @map("band_id") @db.Uuid
  venueName      String   @map("venue_name") @db.VarChar(255)
  venueCity      String   @map("venue_city") @db.VarChar(100)
  venueCountry   String   @map("venue_country") @db.VarChar(100)
  showDate       DateTime @map("show_date")
  status         String   @default("scheduled") @db.VarChar(50)
  ingestNodeId   String?  @map("ingest_node_id") @db.VarChar(100)
  cameraCount    Int      @default(0) @map("camera_count")
  totalContentGb Decimal  @default(0) @map("total_content_gb")
  createdAt      DateTime @default(now()) @map("created_at")

  tour Tour @relation(fields: [tourId], references: [id])
  band Band @relation(fields: [bandId], references: [id])

  @@map("shows")
}
